import controller.EventController;
import model.*;
import view.ConsoleView;
import java.util.List;

public class Main {
    public static void main(String[] args) {
        EventController controller = new EventController();
        ConsoleView view = new ConsoleView();

        // Register sample users
        Admin admin = new Admin("admin1", "pass");
        EventManager manager = new EventManager("mgr1", "pass");
        Consumer consumer = new Consumer("cons1", "pass");

        controller.registerUser(admin);
        controller.registerUser(manager);
        controller.registerUser(consumer);

        // Simulate login
        User loggedIn = controller.login("admin1", "pass");

        if (loggedIn instanceof Admin) {
            view.showAdminMenu();
            controller.adminAddLocation((Admin) loggedIn, new Location("City Hall", 100));
            controller.adminApproveEvent((Admin) loggedIn, new Event("Music Fest", new Location("City Hall", 100), 500.0));
        } else if (loggedIn instanceof EventManager) {
            view.showManagerMenu();
            controller.managerCreateEvent((EventManager) loggedIn, new Event("Music Fest", new Location("City Hall", 100), 500.0));
        } else if (loggedIn instanceof Consumer) {
            view.showConsumerMenu();
            if (!controller.getEvents().isEmpty()) {
                controller.consumerBookEvent((Consumer) loggedIn, controller.getEvents().get(0));
            }
        }
    }
}

