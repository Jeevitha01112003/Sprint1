package model;

import java.util.ArrayList;
import java.util.List;

public class Admin extends User {
    private List<Location> locations = new ArrayList<>();

    public Admin(String userId, String password) {
        super(userId, password, "Admin");
    }

    public void addLocation(Location loc) {
        locations.add(loc);
        System.out.println("Location added: " + loc.getName());
    }

    public void approveEvent(Event event) {
        event.setApproved(true);
        System.out.println("Event approved: " + event.getTitle());
    }

    public List<Location> getLocations() { return locations; }
}





package model;

public abstract class User {
    protected String userId;
    protected String password;
    protected String role;

    public User(String userId, String password, String role) {
        this.userId = userId;
        this.password = password;
        this.role = role;
    }

    public String getUserId() { return userId; }
    public String getRole() { return role; }
    public boolean authenticate(String pwd) { return this.password.equals(pwd); }
}




