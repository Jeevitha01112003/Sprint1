package controller;

import model.*;
import java.util.ArrayList;
import java.util.List;

public class EventController {
    private List<User> users = new ArrayList<>();
    private List<Event> events = new ArrayList<>();

    // Registration & Authentication
    public void registerUser(User user) {
        for (User u : users) {
            if (u.getUserId().equals(user.getUserId())) {
                System.out.println("User ID already exists!");
                return;
            }
        }
        users.add(user);
        System.out.println(user.getRole() + " registered: " + user.getUserId());
    }

    public User login(String userId, String password) {
        for (User u : users) {
            if (u.getUserId().equals(userId) && u.authenticate(password)) {
                System.out.println("Login successful: " + u.getRole());
                return u;
            }
        }
        System.out.println("Invalid credentials!");
        return null;
    }

    // Role-based services
    public void adminAddLocation(Admin admin, Location loc) {
        admin.addLocation(loc);
    }

    public void adminApproveEvent(Admin admin, Event event) {
        admin.approveEvent(event);
    }

    public void managerCreateEvent(EventManager manager, Event event) {
        events.add(event);
        System.out.println("Event created: " + event.getTitle() + " (Pending approval)");
    }

    public void managerCancelEvent(EventManager manager, Event event) {
        event.cancel();
        System.out.println("Event cancelled: " + event.getTitle());
        for (User u : users) {
            if (u instanceof Consumer) {
                ((Consumer) u).addCoupon(new Coupon("COMP-" + event.getTitle()));
            }
        }
    }

    public void consumerBookEvent(Consumer consumer, Event event) {
        if (event.isApproved() && !event.isCancelled()) {
            if (consumer.useCoupon(event)) {
                System.out.println("Ticket booked using coupon for " + consumer.getUserId());
            } else {
                System.out.println("Ticket booked for " + consumer.getUserId() + " at " + event.getTitle() + " | Paid: " + event.getPrice());
            }
        } else {
            System.out.println("Event not available for booking!");
        }
    }

    public List<Event> getEvents() { return events; }
    public List<User> getUsers() { return users; }
}





